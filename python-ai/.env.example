# Copy this file to .env for local dev. Never commit .env.
# Production secrets live in Fly.io (or whichever host) — not in this file.

# --- Supabase (same project as Netlify; same secret as backend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# --- OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_GENERATE_MODEL=gpt-4o-mini
OPENAI_GENERATE_MODEL_STRONG=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# --- Shared secret with the Netlify proxy (`ai-proxy.js`).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Set the SAME value in Netlify env vars.
AI_SERVICE_INTERNAL_TOKEN=replace-with-long-random-string

# --- Misc
LOG_LEVEL=INFO
ENVIRONMENT=development
